
# Required: At least one LLM provider API key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Optional: OpenAI Codex subscription access (uses your ChatGPT/Codex subscription instead of API billing)
# Option A — explicit token:
#   OPENAI_CODEX_TOKEN=sess-...
# Option B — path to auth.json (e.g. if mounted in Docker):
#   OPENAI_CODEX_AUTH_PATH=/app/data/auth.json
# Option C — automatic: ClawRoute reads the default Codex home auth file
OPENAI_CODEX_TOKEN=
OPENAI_CODEX_AUTH_PATH=
# Option D — multiple auth files (rotation): comma-separated paths
#   OPENAI_CODEX_AUTH_PATHS=/path/to/friend1/auth.json,/path/to/friend2/auth.json
#   Rotates round-robin every 2h when idle 30m. Overrides OPENAI_CODEX_AUTH_PATH.
OPENAI_CODEX_AUTH_PATHS=
# Optional: customize rotation timing
# CODEX_ROTATION_INTERVAL_HOURS=2   # Hours between rotations (default: 2)
# CODEX_ROTATION_IDLE_MINUTES=30    # Minutes idle before rotation allowed (default: 30)
# Optional: quota-aware selector rollout for multi-account Codex auth pools
#   off    = legacy round-robin only (default)
#   shadow = compute the recommendation but still use legacy slot choice
#   on     = use alternate schedule lanes until every account has fresh weekly
#            telemetry, then optimize required weekly burn toward each reset
# CODEX_BALANCE_LOADER_MODE=off
# UTC weekday used to stagger first activation/reset telemetry only:
# mon|tue|wed|thu|fri|sat|sun
# CODEX_SCHEDULE_START_DAY=mon
# Enable the next scheduled slot after every active slot reaches the threshold.
# CODEX_EARLY_ACTIVATION_ENABLED=true
# CODEX_EARLY_ACTIVATION_WEEKLY_PERCENT=70

# Optional: Ollama local inference endpoint
# When deployed in Docker through Spartan Gate, use the container name:
#   OLLAMA_ENDPOINT=http://ollama:11434
# For local development outside Docker:
#   OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_ENDPOINT=http://ollama:11434

# Optional: ClawRoute settings
CLAWROUTE_PORT=18790
# IMPORTANT: Set to 0.0.0.0 when running in Docker so other containers can reach ClawRoute.
# Default (127.0.0.1) only accepts connections from the same container.
CLAWROUTE_HOST=0.0.0.0
CLAWROUTE_TOKEN=          # Shared secret for auth (recommended if exposing beyond localhost)
CLAWROUTE_DRY_RUN=false   # Set to "true" to classify + log without actually rerouting
CLAWROUTE_DEBUG=false     # Set to "true" for verbose console logging (redacted)
CLAWROUTE_LOG_CONTENT=false  # DANGER: Set to "true" to log message content (privacy risk)
# CLAWROUTE_PROVIDER=openrouter  # Provider profile to load: openrouter | codex | anthropic | openai
#   Loads config/providers/<name>.json — changes all tier models in one line.
#   Leave unset to use default.json (openrouter) as-is.
