# Example private env. Copy to private/env/local.env and replace placeholders.

TAILSCALE_IP=100.x.y.z
TAILSCALE_HOST=machine-name.tailnet.ts.net
SPARTAN_EDGE_SCHEME=http
# Browser backend profile selected by CAMOFOX_URL.
COMPOSE_PROFILES=browserless
# Optional manual HTTPS. Use a cert valid for TAILSCALE_HOST, not the raw IP.
SPARTAN_CADDY_CERTS_PATH=/absolute/path/to/caddy-certs
SPARTAN_CADDY_TLS_CERT_FILE=/certs/cert.pem
SPARTAN_CADDY_TLS_KEY_FILE=/certs/key.pem

# Private edge ports can differ from public defaults to avoid old stack conflicts.
SPARTAN_BIND_LOCALHOST=127.0.0.1
SPARTAN_GATE_PORT=28789
CLAWROUTE_EDGE_PORT=28790
BROWSERLESS_DEBUG_PORT=23005
HERMES_DASHBOARD_PORT=29119
SPARTAN_INTERNAL_SUBNET=172.29.0.0/24
SPARTAN_DNS_IP=172.29.0.253
SPARTAN_ALLOW_EXISTING_STACK_PATHS=false

SPARTAN_HERMES_DATA_PATH=/absolute/path/to/spartan-gate/hermes
SPARTAN_HERMES_RUN_UID=
SPARTAN_HERMES_RUN_GID=
SPARTAN_PROXY_AUDIT_LOG=/opt/data/logs/proxy-audit.log
SPARTAN_CLAWROUTE_DATA_PATH=/absolute/path/to/spartan-gate/clawroute
SPARTAN_GOGCLI_DATA_PATH=/absolute/path/to/spartan-gate/gogcli
SPARTAN_BROWSERLESS_PROFILES_PATH=/absolute/path/to/spartan-gate/browserless-profiles
SPARTAN_CAMOFOX_DATA_PATH=/absolute/path/to/spartan-gate/camofox
SPARTAN_CAMOFOX_ADDONS_PATH=/absolute/path/to/spartan-gate/camofox/addons
BROWSERLESS_PROFILES_GID=1000

CADDY_AUTH_USER=admin
# Generate with: docker run --rm caddy:2-alpine@sha256:86deaf5e3d3408a6ccec08fbb79989783dd26e206ae10bcf78a801dc8c9ab794 caddy hash-password --plaintext '<password>'
CADDY_AUTH_HASH='$2a$14$UMuSzA3WdVqcAwE3yvFeCO.CesMjqqGDVrxpL1s87FsWM/NRrADi2'

HERMES_API_KEY=change-me
HERMES_GATEWAY_TOKEN=change-me
CLAWROUTE_TOKEN=change-me
BROWSERLESS_TOKEN=change-me
BROWSERLESS_IMAGE=ghcr.io/browserless/chromium:v2.51.0
BROWSERLESS_DEBUG_ORIGIN=
# Persistent login profile used by the optional browser profile main.
# For Google Meet with an authenticated account, use BROWSERLESS_PROFILE=google
# together with HERMES_MEET_CDP_PROFILE=google, then seed accounts.google.com.
BROWSERLESS_PROFILE=main
BROWSERLESS_CDP_BROKER_ENABLED=true
BROWSERLESS_CDP_BROKER_PORT=9229
BROWSERLESS_CDP_BROKER_TRACE=false
BROWSERLESS_SESSION_TIMEOUT_MS=2147483647
BROWSERLESS_IGNORE_DEFAULT_ARGS=false
BROWSERLESS_HEADLESS=true
BROWSERLESS_STEALTH_ENDPOINT=true
BROWSERLESS_ROUTE=chromium
BROWSERLESS_STEALTH_ROUTE=chromium
BROWSERLESS_LANG=es-ES
BROWSERLESS_USER_AGENT=
BROWSERLESS_TZ=Europe/Madrid
SPARTAN_WHITELIST_REFRESH_TIME=02:00
SPARTAN_WHITELIST_REFRESH_TZ=Europe/Madrid
HERMES_MEET_CDP_PROFILE=guest
# Override Meet to use real host Chrome CDP instead of Browserless, e.g. http://172.29.0.1:9222
HERMES_MEET_CDP_URL=
# If your private Caddy config enables TLS, use the certificate hostname.
# SPARTAN_EDGE_SCHEME=https
# TAILSCALE_HOST=machine-name.tailnet.ts.net
# Optional explicit override for the profile-seeding link:
# BROWSERLESS_DEBUG_ORIGIN=https://machine-name.tailnet.ts.net:23005
BROWSERLESS_LIVE_TIMEOUT_MS=900000
BROWSERLESS_LIVE_QUALITY=90
BROWSERLESS_LIVE_RESIZABLE=false

# Optional Camofox browser backend. Leave CAMOFOX_URL empty to keep Browserless
# as Hermes' default browser/CDP backend.
CAMOFOX_URL=
CAMOFOX_BASE_IMAGE=ghcr.io/jo-inc/camofox-browser:1.11.2
CAMOFOX_IMAGE=spartan-gate-camofox:1.11.2
CAMOFOX_ACCESS_KEY=change-me-camofox-access-key
CAMOFOX_API_KEY=
CAMOFOX_ADMIN_KEY=
CAMOFOX_USER_ID=
CAMOFOX_SESSION_KEY=
CAMOFOX_ADOPT_EXISTING_TAB=true
CAMOFOX_GEOIP=false
CAMOFOX_ADDONS=
# Example after installing the add-on under SPARTAN_CAMOFOX_ADDONS_PATH:
# CAMOFOX_ADDONS=/opt/camofox-addons/web-clipper-obsidian
CAMOFOX_ENABLE_VNC=0
CAMOFOX_VNC_PASSWORD=
CAMOFOX_NOVNC_PORT=26080
CAMOFOX_MAX_CONCURRENT_PER_USER=2
CAMOFOX_MAX_SESSIONS=8
CAMOFOX_MAX_TABS_PER_SESSION=4
CAMOFOX_MAX_TABS_GLOBAL=12
CAMOFOX_SESSION_TIMEOUT_MS=600000
CAMOFOX_TAB_INACTIVITY_MS=300000
CAMOFOX_BROWSER_IDLE_TIMEOUT_MS=300000
CAMOFOX_TRACES_MAX_BYTES=52428800
CAMOFOX_TRACES_TTL_HOURS=24
CAMOFOX_MAX_OLD_SPACE_SIZE=256

HERMES_DASHBOARD=1
HERMES_DASHBOARD_INSECURE=1
HERMES_API_PORT=8642
HERMES_MAX_ITERATIONS=90
HERMES_DUMP_REQUESTS=false
HERMES_DUMP_REQUEST_STDOUT=false

# Legacy bootstrap: comma-separated profile names to seed as running for s6.
# Keep blank until each listed profile has its own token and explicit API port.
# Existing gateway_state.json wins; use `hermes -p <profile> gateway start|stop`
# for normal lifecycle changes.
HERMES_AUTOSTART_PROFILES=

# Main gateway messaging.
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_TELEGRAM_ALLOWED_USERS=
TELEGRAM_DM_POLICY=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=

# Autostart profile examples. Copy the pattern for more profiles.
HERMES_TELEGRAM_BOT_TOKEN_COACH=
HERMES_TELEGRAM_ALLOWED_USERS_COACH=
DISCORD_BOT_TOKEN_COACH=
DISCORD_ALLOWED_USERS_COACH=
DISCORD_HOME_CHANNEL_COACH=
HERMES_TELEGRAM_BOT_TOKEN_WORK=
HERMES_TELEGRAM_ALLOWED_USERS_WORK=
DISCORD_BOT_TOKEN_WORK=
DISCORD_ALLOWED_USERS_WORK=
DISCORD_HOME_CHANNEL_WORK=
HERMES_TELEGRAM_BOT_TOKEN_MARKET=
HERMES_TELEGRAM_ALLOWED_USERS_MARKET=
DISCORD_BOT_TOKEN_MARKET=
DISCORD_ALLOWED_USERS_MARKET=
DISCORD_HOME_CHANNEL_MARKET=

GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_EMAIL=
COPILOT_GITHUB_TOKEN=
RAINDROP_API_KEY=
GOOGLE_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
GOG_KEYRING_PASSWORD=
GOGCLI_ACCOUNT=
GOGCLI_CLIENT_SECRET_PATH=
# Leave empty to use the helper default: Analytics, Tag Manager, and Apps Script scopes.
GOGCLI_EXTRA_SCOPES=
FRED_API_KEY=
MASSIVE_API_KEY=
FINNHUB_API_KEY=

CLAWROUTE_ENABLED=true
CLAWROUTE_BASELINE_MODEL=openrouter/anthropic/claude-sonnet-4.6
CLAWROUTE_PROVIDER=
CLAWROUTE_DEBUG=false
CLAWROUTE_DRY_RUN=false
CLAWROUTE_LOG_CONTENT=false
CODEX_EARLY_ACTIVATION_ENABLED=true
CODEX_EARLY_ACTIVATION_WEEKLY_PERCENT=70
CODEX_ROTATION_INTERVAL_HOURS=2
CODEX_ROTATION_IDLE_MINUTES=30
CODEX_BALANCE_LOADER_MODE=off
CODEX_SCHEDULE_START_DAY=mon
CODEX_COLD_MIGRATION_FIVE_HOUR_THRESHOLD_PERCENT=7
CODEX_COLD_MIGRATION_DECISION_TTL_HOURS=6
OLLAMA_ENDPOINT=http://ollama:11434

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
STEPFUN_API_KEY=
OPENAI_CODEX_TOKEN=
OPENAI_CODEX_AUTH_PATH=
OPENAI_CODEX_AUTH_PATHS=
CODEX_HOME=

CLAWROUTE_ALERT_EMAIL=
CLAWROUTE_ALERT_SLACK_WEBHOOK=

READER_TIMEOUT=15
